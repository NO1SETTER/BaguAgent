{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["questions", "chains"],
  "properties": {
    "questions": {
      "type": "array",
      "items": { "$ref": "#/$defs/question" }
    },
    "chains": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["chain_id", "topic", "root_knowledge_point", "chain_goal", "difficulty_progression", "questions"],
        "properties": {
          "chain_id": { "type": "string" },
          "topic": { "type": "string" },
          "root_knowledge_point": { "type": "string" },
          "chain_goal": { "type": "string" },
          "difficulty_progression": { "type": "array", "items": { "type": "string" } },
          "questions": {
            "type": "array",
            "minItems": 3,
            "maxItems": 5,
            "items": { "$ref": "#/$defs/question" }
          }
        }
      }
    }
  },
  "$defs": {
    "question": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "question_id",
        "topic",
        "topic_id",
        "concept",
        "source_type",
        "difficulty",
        "question",
        "expected_points",
        "reference_answer",
        "follow_up_direction",
        "source_chunks",
        "quality_flags"
      ],
      "properties": {
        "question_id": { "type": "string" },
        "topic": { "type": "string" },
        "topic_id": { "type": "string" },
        "concept": { "type": "string" },
        "source_type": { "enum": ["bagu_local", "note_readonly", "expanded"] },
        "difficulty": { "enum": ["basic", "medium", "hard"] },
        "question": { "type": "string" },
        "expected_points": { "type": "array", "items": { "type": "string" } },
        "reference_answer": { "type": "string" },
        "follow_up_direction": { "type": "string" },
        "source_chunks": { "type": "array", "items": { "type": "string" } },
        "quality_flags": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
