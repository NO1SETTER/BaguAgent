{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["topics", "concepts"],
  "properties": {
    "topics": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "topic_id",
          "name",
          "aliases",
          "category",
          "confidence",
          "enabled",
          "can_write_back_to_bagu",
          "source_files",
          "covered_sections"
        ],
        "properties": {
          "topic_id": { "type": "string" },
          "name": { "type": "string" },
          "aliases": { "type": "array", "items": { "type": "string" } },
          "category": { "type": "string" },
          "confidence": { "type": "number" },
          "enabled": { "type": "boolean" },
          "can_write_back_to_bagu": { "type": "boolean" },
          "source_files": { "type": "array", "items": { "type": "string" } },
          "covered_sections": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["section_id", "file", "path", "source_type"],
              "properties": {
                "section_id": { "type": "string" },
                "file": { "type": "string" },
                "path": { "type": "array", "items": { "type": "string" } },
                "source_type": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "concepts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["concept_id", "topic_id", "name", "aliases", "source_files", "linked_chunks"],
        "properties": {
          "concept_id": { "type": "string" },
          "topic_id": { "type": "string" },
          "name": { "type": "string" },
          "aliases": { "type": "array", "items": { "type": "string" } },
          "source_files": { "type": "array", "items": { "type": "string" } },
          "linked_chunks": { "type": "array", "items": { "type": "string" } }
        }
      }
    }
  }
}
