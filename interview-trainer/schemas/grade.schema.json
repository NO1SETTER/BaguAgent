{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["average_score", "summary", "topic_summary", "reviews", "chain_reviews", "knowledge_candidates"],
  "properties": {
    "average_score": { "type": "number" },
    "summary": { "type": "string" },
    "topic_summary": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["topic", "summary", "average_score"],
        "properties": {
          "topic": { "type": "string" },
          "summary": { "type": "string" },
          "average_score": { "type": "number" }
        }
      }
    },
    "reviews": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "question_id",
          "score",
          "level",
          "covered_points",
          "missed_points",
          "incorrect_points",
          "feedback",
          "better_answer",
          "follow_up_question"
        ],
        "properties": {
          "question_id": { "type": "string" },
          "score": { "type": "number", "minimum": 0, "maximum": 100 },
          "level": { "enum": ["correct", "partial", "wrong"] },
          "covered_points": { "type": "array", "items": { "type": "string" } },
          "missed_points": { "type": "array", "items": { "type": "string" } },
          "incorrect_points": { "type": "array", "items": { "type": "string" } },
          "feedback": { "type": "string" },
          "better_answer": { "type": "string" },
          "follow_up_question": { "type": "string" }
        }
      }
    },
    "chain_reviews": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["chain_id", "chain_score", "breakdown_question_index", "weakest_follow_up_type", "feedback"],
        "properties": {
          "chain_id": { "type": "string" },
          "chain_score": { "type": "number" },
          "breakdown_question_index": { "type": "number" },
          "weakest_follow_up_type": { "type": "string" },
          "feedback": { "type": "string" }
        }
      }
    },
    "knowledge_candidates": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["candidate_id", "topic", "title", "summary", "content"],
        "properties": {
          "candidate_id": { "type": "string" },
          "topic": { "type": "string" },
          "title": { "type": "string" },
          "summary": { "type": "string" },
          "content": { "type": "string" }
        }
      }
    }
  }
}
